{
  "name": "curate-backend",
  "version": "1.0.0",
  "description": "Curate backend - Express + MongoDB + Claude Agent",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "seed": "node src/seed/seedDemoData.js",
    "ingest:justwatch": "cd ingest && python justwatch_ingest.py --count 250 --include-curated",
    "import:justwatch": "node src/seed/importJustWatchData.js",
    "refresh:justwatch": "npm run ingest:justwatch && npm run import:justwatch",
    "ingest:catalog": "cd ingest && python justwatch_ingest.py --count 250 --include-curated",
    "import:catalog": "node src/seed/importJustWatchData.js",
    "refresh:catalog": "npm run ingest:catalog && npm run import:catalog",
    "verify:catalog": "node src/seed/verifyCatalog.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.19.4"
  }
}
